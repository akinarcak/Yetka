# Yetka bare-metal installer configuration.
# Copy to /etc/yetka-install.env, fill secrets locally and keep mode 0600.

YETKA_GIT_URL=https://github.com/akinarcak/Yetka.git
YETKA_GIT_REF=yetka-1.0.4
YETKA_INSTALL_DIR=/opt/yetka
YETKA_DATA_DIR=/var/lib/yetka
YETKA_CONFIG_DIR=/etc/yetka
YETKA_USER=yetka
YETKA_DOMAIN=yetka.example.com
YETKA_HTTP_PORT=8080

# standalone: local PostgreSQL + local Redis. CHANGE_LOCALLY database values
# are ignored and secure local values are generated in this mode.
# external:   externally managed PostgreSQL + Redis/Sentinel
YETKA_DATA_MODE=external
DB_ENGINE=postgresql
DB_HOST=10.20.0.10
DB_PORT=5432
DB_NAME=yetka
DB_USER=yetka
DB_PASSWORD=CHANGE_LOCALLY
DB_USE_SSL=false

# For Redis Sentinel, leave REDIS_HOST empty and use entries in the form
# host:port:service-name separated by commas.
REDIS_HOST=10.20.0.20
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_LOCALLY
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_PASSWORD=

# Must be identical on every application/connector node. When left empty the
# first node generates them; copy /etc/yetka/cluster-secrets.env to other nodes.
SECRET_KEY=
BOOTSTRAP_TOKEN=

# web: API/web process; worker: Celery worker; scheduler: the single Celery beat
# node. A small standalone node normally enables all three.
YETKA_ENABLE_WEB=true
YETKA_ENABLE_WORKER=true
YETKA_ENABLE_SCHEDULER=true

# Keep enabled unless an equivalent internal vulnerability scanner and advisory
# process is operating in a disconnected network.
YETKA_MAINTENANCE_CHECK_ENABLED=true
# Upstream is an engineering review channel, not an installable Yetka version.
YETKA_UPSTREAM_BASE_VERSION=v4.10.17

# The updater backs up persistent data by default. Set false only when shared
# storage has an independently tested snapshot/restore policy.
YETKA_UPDATE_BACKUP_DATA=true
YETKA_BACKUP_ROOT=/var/backups/yetka

# Optional prebuilt UI archives. The Yetka release workflow publishes files as
# lina-<yetka-tag>.tar.gz and luna-<yetka-tag>.tar.gz. Pin their SHA-256 values
# from the same release. Empty URLs install only the control-plane API.
YETKA_LINA_URL=
YETKA_LINA_SHA256=
YETKA_LUNA_URL=
YETKA_LUNA_SHA256=

# Optional Koko archive named koko-<yetka-tag>-linux-amd64.tar.gz.
YETKA_KOKO_URL=
YETKA_KOKO_SHA256=
