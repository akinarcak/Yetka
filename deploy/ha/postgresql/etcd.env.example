NODE_NAME=etcd1
NODE_IP=10.20.0.11
ETCD_INITIAL_CLUSTER=etcd1=https://10.20.0.11:2380,etcd2=https://10.20.0.12:2380,etcd3=https://10.20.0.13:2380
ETCD_CLUSTER_TOKEN=yetka-postgresql-dcs
ETCD_VERSION=v3.7.0

# Copy a private CA-signed node certificate to these paths before running.
# The certificate needs serverAuth/clientAuth and IP/DNS SANs for this node.
ETCD_CA_FILE=/root/etcd-pki/ca.crt
ETCD_CERT_FILE=/root/etcd-pki/etcd1.crt
ETCD_KEY_FILE=/root/etcd-pki/etcd1.key
