# Unique on every database node
NODE_NAME=pg1
NODE_IP=10.20.0.11

# Identical on every database node
CLUSTER_NAME=yetka-pg
ETCD_ENDPOINTS=10.20.0.11:2379,10.20.0.12:2379,10.20.0.13:2379
# mTLS files readable by the postgres user (copied from the etcd PKI)
ETCD_CA_FILE=/root/patroni-pki/ca.crt
ETCD_CERT_FILE=/root/patroni-pki/patroni.crt
ETCD_KEY_FILE=/root/patroni-pki/patroni.key
POSTGRES_PASSWORD=CHANGE_LOCALLY
REPLICATION_PASSWORD=CHANGE_LOCALLY
PATRONI_API_PASSWORD=CHANGE_LOCALLY
YETKA_DB_NAME=yetka
YETKA_DB_USER=yetka
YETKA_DB_PASSWORD=CHANGE_LOCALLY
PG_ALLOWED_CIDR=10.20.0.0/16

# The installer supports Debian/Ubuntu and RHEL-family systemd distributions.
PG_DATA_DIR=/var/lib/pgsql/yetka
